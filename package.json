{
  "name": "mangasettlement",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "init": "tsx src/init.ts",
    "dev": "concurrently \"tsx watch src/server.ts\" \"vite --host 0.0.0.0\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p frontend/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "iconv-lite": "^0.6.3",
    "image-size": "^1.2.0",
    "mime-types": "^2.1.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5",
    "vite": "^6.0.7",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/yauzl": "^2.10.3",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
